{
  "name": "smart-health-reminder",
  "private": true,
  "workspaces": ["apps/frontend", "apps/backend"],
  "scripts": {
    "frontend:start": "npm --workspace @smart-health/frontend run start",
    "frontend:android": "npm --workspace @smart-health/frontend run android",
    "frontend:ios": "npm --workspace @smart-health/frontend run ios",
    "frontend:web": "npm --workspace @smart-health/frontend run web",
    "frontend:typecheck": "npm --workspace @smart-health/frontend run typecheck",
    "backend:typecheck": "npm --workspace @smart-health/backend run typecheck",
    "backend:test:domain": "npm --workspace @smart-health/backend run test:domain",
    "backend:test:persistence": "npm --workspace @smart-health/backend run test:persistence",
    "typecheck": "npm run frontend:typecheck && npm run backend:typecheck"
  }
}
